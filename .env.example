# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
POSTGRES_USER=tracker
POSTGRES_PASSWORD=tracker_pass
POSTGRES_DB=restaurant_tracker
DATABASE_URL=postgresql+asyncpg://tracker:tracker_pass@localhost:3018/restaurant_tracker
# ──────────────────────────────────────────────
# Authentication / Server
# ──────────────────────────────────────────────
API_KEY=changeme-set-a-real-key
CORS_ORIGINS=["http://localhost:3003"]

# ──────────────────────────────────────────────
# Identity resolution thresholds (CALIBRATE on your footage)
# ──────────────────────────────────────────────
RETURNING_FACE_THRESHOLD=0.55
REJECT_SIMILARITY=0.35
AMBIGUITY_MARGIN=0.05
STRONG_MATCH_THRESHOLD=0.65
NEW_VISITOR_MAX_SIMILARITY=0.45

# Body (OSNet) re-ID is clothing-dependent → same-session only, OFF by default.
ALLOW_BODY_FALLBACK=false
RETURNING_BODY_THRESHOLD=0.55

# ──────────────────────────────────────────────
# Gallery management
# ──────────────────────────────────────────────
# Keep more face embeddings per person (more multi-pose data = better recall).
# Merges only trim faces ABOVE this cap, so a higher value preserves embeddings.
MAX_FACES_PER_VISITOR=30
FACE_QUALITY_CUTOFF=0.45

# ──────────────────────────────────────────────
# Visit sessions
# ──────────────────────────────────────────────
VISIT_COOLDOWN_MINUTES=20
MAX_VISIT_DURATION_HOURS=4
STALE_CHECK_INTERVAL_SECONDS=60

# ──────────────────────────────────────────────
# Camera
# ──────────────────────────────────────────────
CAMERA_SOURCE=0
CAMERA_FPS=1.0
CAMERA_ID=cam-0
CAMERA_AUTOSTART=false
FRAME_DEDUP_ENABLED=true
FRAME_DEDUP_MAD_THRESHOLD=4.0
MAX_FRAME_LONG_SIDE=1280
CAMERAS=cam-web=0;rtsp://admin:Senrysa%232026@192.168.1.64:554/Streaming/Channels/101
CAMERA_AUTOSTART=true
# ──────────────────────────────────────────────
# Models (CPU only)
# ──────────────────────────────────────────────
YOLO_MODEL_PATH=yolov8n.pt
YOLO_USE_ONNX=true
INSIGHTFACE_MODEL_NAME=buffalo_l
INSIGHTFACE_DET_SIZE=640
BODY_MODEL_TYPE=osnet
CPU_THREADS=0
INFERENCE_MAX_CONCURRENCY=1

# ──────────────────────────────────────────────
# Upload limits (/api/detect)
# ──────────────────────────────────────────────
VIDEO_MAX_SIZE_MB=100
VIDEO_MAX_DURATION_SECONDS=60
FRAMES_PER_SECOND=1

# ──────────────────────────────────────────────
# Privacy / retention (0 = keep forever; biometric data may be regulated)
# ──────────────────────────────────────────────
VISITOR_RETENTION_DAYS=0
RETENTION_PURGE_INTERVAL_HOURS=24
