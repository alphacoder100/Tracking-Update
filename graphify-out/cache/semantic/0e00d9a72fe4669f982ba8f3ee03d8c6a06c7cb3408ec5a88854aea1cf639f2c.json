{"nodes": [{"id": "IMPROVEMENT_PLAN_MD", "label": "Accuracy & Performance Improvement Plan", "file_type": "document", "source_file": "IMPROVEMENT_PLAN.md", "source_location": null, "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null}, {"id": "IMPROVEMENT_hnsw_ef_search_tuning", "label": "HNSW ef_search Tuning", "file_type": "rationale", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 1.1", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null, "rationale": "Set hnsw.ef_search=100 (via SET LOCAL) per resolve transaction to prevent filtered queries from exhausting graph candidates and re-registering returning visitors as new."}, {"id": "IMPROVEMENT_per_person_arcface_fallback_gating", "label": "Per-person ArcFace Fallback Gating", "file_type": "rationale", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 1.2", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null, "rationale": "Gate the second per-person ArcFace pass behind PER_PERSON_FACE_FALLBACK so deployments with strong full-frame face detection can avoid N extra ArcFace forward passes per crowded frame."}, {"id": "IMPROVEMENT_empty_frame_early_out", "label": "Empty-Frame Early-Out", "file_type": "rationale", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 1.3", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null, "rationale": "Skip per-person and body-queue loops when YOLO finds no persons AND ArcFace finds no faces."}, {"id": "IMPROVEMENT_tracklet_fast_path", "label": "Tracklet Fast-Path", "file_type": "rationale", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 1.4", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null, "rationale": "Pin visitor_id and verified_embedding on a confident tracklet match; attribute later frames directly without gallery search. Drift guard re-verifies on time, IoU, or face drift."}, {"id": "IMPROVEMENT_consolidate_per_match_db_round_trips", "label": "Consolidate Per-Match DB Round-Trips", "file_type": "rationale", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 2.1", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null, "rationale": "Fetch visitor gallery (embedding, det_score, pose_bin, body_embedding) once per match instead of three sequential SELECTs in auto_enroller.update_after_match."}, {"id": "IMPROVEMENT_masked_face_periocular_batching", "label": "Masked-Face Periocular Batching", "file_type": "rationale", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 2.2", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null, "rationale": "Batch periocular ArcFace embeds across masked faces in the frame and short-circuit mask detection when MASK_DETECTION_ENABLED is off."}, {"id": "IMPROVEMENT_persist_ef_search_at_role_level", "label": "Persist ef_search at Index/Role Level", "file_type": "rationale", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 2.3", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null, "rationale": "Belt-and-suspenders ALTER DATABASE ... SET hnsw.ef_search=100 so future queries missing SET LOCAL still benefit."}, {"id": "IMPROVEMENT_fused_score_reranking", "label": "Fused-Score Re-Ranking of Candidates", "file_type": "rationale", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 2.4", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null, "rationale": "Compute w_f*face_sim + w_b*body_sim fused score for same-session grey-zone candidates before the ambiguity gate (not across visits)."}, {"id": "IMPROVEMENT_detector_input_size_auto_selection", "label": "Detector Input-Size Auto-Selection", "file_type": "rationale", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 2.5", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null, "rationale": "Auto-pick INSIGHTFACE_DET_SIZE (640/480/320) based on median detected face size over a warmup window for speed/recall trade."}, {"id": "IMPROVEMENT_model_upgrades_evaluate", "label": "Model Upgrades (Evaluate, Don't Rush)", "file_type": "rationale", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 2.6", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null, "rationale": "Evaluate AdaFace (pose/low-quality) and BoT-SORT/StrongSORT (occlusion robustness) as drop-in replacements behind config, A/B on detection_events."}, {"id": "CONCEPT_hnsw", "label": "HNSW Vector Index (pgvector)", "file_type": "rationale", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 1.1", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null}, {"id": "MODULE_auto_enroller", "label": "auto_enroller.update_after_match", "file_type": "code", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 2.1", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null}, {"id": "MODULE_detection_pipeline", "label": "detection_pipeline.process_detections", "file_type": "code", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 2.2", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null}, {"id": "MIGRATION_001_restaurant_schema", "label": "alembic/versions/001_restaurant_schema.py", "file_type": "code", "source_file": "IMPROVEMENT_PLAN.md", "source_location": "Section 1.1", "source_url": null, "captured_at": "2026-06-23", "author": null, "contributor": null}], "edges": [{"source": "IMPROVEMENT_PLAN_MD", "target": "ADVANCED_OPTIMIZATION_AND_DEDUPLICATION_PLAN_MD", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "IMPROVEMENT_PLAN.md", "source_location": "line 6", "weight": 1.0}, {"source": "IMPROVEMENT_hnsw_ef_searc