# Copy to .env.local for native `npm run dev`.

# Backend base URL the SERVER-SIDE proxy forwards to (keeps API_KEY off the client).
# Native: http://localhost:3001   |   Docker compose: http://backend:8000
BACKEND_URL=http://localhost:3001

# Must match the backend's API_KEY (.env). Used only server-side by the proxy.
API_KEY=changeme-set-a-real-key

# WebSocket the BROWSER connects to directly for the live feed (not proxied).
# This must be reachable from the browser, i.e. the backend's published host port.
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws/live-feed
